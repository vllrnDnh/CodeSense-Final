{
  "name": "codesense-backend",
  "version": "1.0.0",
  "description": "Intelligent C++ Static Analysis Engine for Novice Programmers",
  "main": "dist/backend/src/server.js",
  "scripts": {
    "clean": "rimraf dist",
    "build:parser": "peggy --format commonjs -o src/analysis/parser.js grammar/cpp.pegjs",
    "build:ts": "tsc -p .",
    "copy:parser": "shx mkdir -p dist/backend/src/analysis && shx cp src/analysis/parser.js dist/backend/src/analysis/parser.js",
    "build": "npm run clean && npm run build:parser && npm run build:ts && npm run copy:parser",
    "dev": "ts-node src/server.ts",
    "start": "node dist/backend/src/server.js"
  },
  "keywords": [
    "cpp",
    "parser",
    "static-analysis",
    "education",
    "gamification"
  ],
  "author": "CodeSense Team",
  "license": "ISC",
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "axios": "^1.13.4",
    "body-parser": "^2.2.2",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "firebase": "^12.9.0",
    "peggy": "^3.0.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.11.0",
    "nodemon": "^3.0.3",
    "rimraf": "^5.0.5",
    "shx": "^0.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "dompurify": "^3.3.1"
  }
}
