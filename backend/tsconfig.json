{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",        // ← changed from "../"
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "allowSyntheticDefaultImports": true,
    "types": ["node"],

    "ignoreDeprecations": "5.0"
    // removed @shared paths since there's no shared folder
  },
  "include": [
    "src/**/*"                 // ← removed "../shared/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}